# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
EXECUTION_MODE=disabled

# ─── Network ────────────────────────────────────────────────────────────────
# Set to your machine's LAN IP to access the app from other devices on your network
# LOCAL_IP=192.168.1.100

# ─── Database (SQLite) ───────────────────────────────────────────────────────
DATABASE_PATH=./data/brain.sqlite

# ─── Polymarket ──────────────────────────────────────────────────────────────
POLYMARKET_API_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=

# ─── Price Feeds ─────────────────────────────────────────────────────────────
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com
PRICE_FEED_SYMBOL=BTCUSDT

# ─── Agent / LLM ────────────────────────────────────────────────────────────
AGENT_PROVIDER=openai
AGENT_MODEL=gpt-4o
AGENT_TIMEOUT_MS=30000
AGENT_MAX_RETRIES=2
AGENT_TEMPERATURE=0
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ─── Whale Tracker ──────────────────────────────────────────────────────────
MEMPOOL_WS_URL=wss://mempool.space/api/v1/ws
WHALE_THRESHOLD_BTC=10

# ─── Pipeline Orchestrator ──────────────────────────────────────────────────
PIPELINE_INTERVAL_MS=2000
INITIAL_BALANCE_USD=100
# FEATURE_ENGINE_URL=http://localhost:3004
# AGENT_GATEWAY_URL=http://localhost:3008
# RISK_SERVICE_URL=http://localhost:3005
# EXECUTION_SERVICE_URL=http://localhost:3006

# ─── Risk (NOTE: these are NOT read by the service — use POST /api/v1/risk/config) ───
# RISK_MAX_SIZE_USD=0.5
# RISK_DAILY_LOSS_LIMIT_USD=10
# RISK_MAX_SPREAD_BPS=300
# RISK_MIN_DEPTH_SCORE=0.1
# RISK_MAX_TRADES_PER_WINDOW=1

# ─── Post-Trade Analyzer ────────────────────────────────────────────────────
ANALYZER_MODEL=gpt-4o
ANALYZER_TIMEOUT_MS=60000

# ─── Strategy Optimizer ─────────────────────────────────────────────────────
OPTIMIZER_MODEL=gpt-4o
OPTIMIZER_TIMEOUT_MS=120000
OPTIMIZER_INTERVAL_MS=86400000
AUTO_APPLY_ENABLED=false
